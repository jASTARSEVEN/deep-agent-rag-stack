{
  "name": "deep-agent-web",
  "version": "0.1.0",
  "private": true,
  "author": "卓品至 <easypinex@gmail.com>",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "dev:e2e": "vite --host 127.0.0.1 --port 13001",
    "api:e2e": "node ./tests/e2e/scripts/start-e2e-api.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "test:e2e:prepare": "node ./tests/e2e/scripts/prepare-e2e.mjs",
    "test:e2e": "npm run test:e2e:prepare && playwright test",
    "test:smoke:keycloak": "playwright test -c playwright.smoke.config.ts",
    "test:e2e:headed": "npm run test:e2e:prepare && playwright test --headed",
    "test:e2e:ui": "npm run test:e2e:prepare && playwright test --ui"
  },
  "dependencies": {
    "keycloak-js": "^26.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
