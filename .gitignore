# 根目錄 git 忽略規則，避免提交機敏資訊、建置產物與本機快取。

# Environment files
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.venv/
venv/
env/
pip-wheel-metadata/

# Node.js
node_modules/
dist/
build/
.vite/
coverage/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Logs and runtime files
*.log
*.pid
*.pid.lock

# Local Docker and compose overrides
docker-compose.override.yml

# MinIO, database, and local storage artifacts
*.sqlite3
*.sqlite
*.db
data/
tmp/
apps/web/.tmp/
apps/web/playwright-report/
apps/web/test-results/

# Build outputs
*.egg-info/
.eggs/
