# Root environment template for local Docker Compose development.
# 本機 Docker Compose 開發使用的根目錄環境變數範本。

# ============================================================================
# Compose project
# Docker Compose 專案設定
# ============================================================================

# Docker Compose project name used for container, network, and volume prefixes.
# Docker Compose 專案名稱，會影響 container、network、volume 的前綴。
COMPOSE_PROJECT_NAME=deep-agent-rag-stack

# ============================================================================
# Public reverse proxy / TLS
# 對外 reverse proxy / TLS 設定
# ============================================================================

# Public hostname served by Caddy.
# Caddy 對外服務使用的公開 hostname。
PUBLIC_HOST=localhost
# Public base URL served by Caddy.
# Caddy 對外服務使用的公開 base URL。
PUBLIC_BASE_URL=http://localhost
# ACME contact email used by Caddy automatic HTTPS.
# Caddy 自動申請與續約憑證使用的 ACME 聯絡信箱。
TLS_ACME_EMAIL=admin@example.com
# Whether to use the Let's Encrypt staging CA.
# 是否使用 Let's Encrypt staging CA，避免正式 rate limit。
TLS_ACME_STAGING=false
# Whether Keycloak admin console should be exposed through the reverse proxy.
# 是否透過 reverse proxy 對外公開 Keycloak admin console。
KEYCLOAK_EXPOSE_ADMIN=false

# ============================================================================
# Public URLs
# 對外公開 URL
# ============================================================================

# Public web origin exposed to browsers.
# 提供瀏覽器使用的 Web 公開 URL。
WEB_PUBLIC_URL=http://localhost
# Public API origin exposed to browsers.
# 提供瀏覽器使用的 API 公開 URL。
API_PUBLIC_URL=http://localhost/api
# Public Keycloak origin exposed to browsers.
# 提供瀏覽器使用的 Keycloak 公開 URL。
KEYCLOAK_PUBLIC_URL=http://localhost/auth

# ============================================================================
# Application database
# 應用程式資料庫
# ============================================================================

# PostgreSQL application database name.
# 應用程式 PostgreSQL 資料庫名稱。
POSTGRES_DB=deep_agent_rag
# PostgreSQL application database username.
# 應用程式 PostgreSQL 資料庫使用者名稱。Supabase Postgres init scripts 預設需要 `postgres` superuser。
POSTGRES_USER=postgres
# PostgreSQL application database password.
# 應用程式 PostgreSQL 資料庫密碼。
POSTGRES_PASSWORD=postgres
# Host port exposed for the application PostgreSQL container.
# 應用程式 PostgreSQL 容器對外暴露的主機連接埠。
POSTGRES_PORT=15432

# ============================================================================
# Redis
# Redis 設定
# ============================================================================

# Host port exposed for the Redis container.
# Redis 容器對外暴露的主機連接埠。
REDIS_PORT=16379

# ============================================================================
# MinIO infrastructure
# MinIO 基礎設施設定
# ============================================================================

# MinIO root username for object storage administration.
# MinIO 物件儲存管理用 root 使用者名稱。
MINIO_ROOT_USER=minio
# MinIO root password for object storage administration.
# MinIO 物件儲存管理用 root 密碼。
MINIO_ROOT_PASSWORD=minio123
# Host port exposed for the MinIO S3-compatible API.
# MinIO S3 相容 API 對外暴露的主機連接埠。
MINIO_PORT=19000
# Host port exposed for the MinIO console UI.
# MinIO 管理主控台 UI 對外暴露的主機連接埠。
MINIO_CONSOLE_PORT=19001
# Bucket name used for uploaded documents.
# 文件上傳使用的 bucket 名稱。
MINIO_BUCKET=documents

# ============================================================================
# Keycloak infrastructure
# Keycloak 基礎設施設定
# ============================================================================

# Initial Keycloak admin username.
# 初始 Keycloak 管理者帳號。
KEYCLOAK_ADMIN=admin
# Initial Keycloak admin password.
# 初始 Keycloak 管理者密碼。
KEYCLOAK_ADMIN_PASSWORD=admin
# Realm name imported into Keycloak for local development.
# 本機開發時匯入 Keycloak 的 realm 名稱。
KEYCLOAK_REALM=deep-agent-dev
# Keycloak OIDC client ID used by the web frontend.
# Web 前端登入流程使用的 Keycloak client ID。
KEYCLOAK_CLIENT_ID=deep-agent-web
# JWT claim name that carries Keycloak groups.
# JWT 中承載 Keycloak groups 的 claim 名稱。
KEYCLOAK_GROUPS_CLAIM=groups
# Internal Keycloak base URL used by API / worker.
# API / worker 容器內部使用的 Keycloak 基底 URL。
KEYCLOAK_URL=http://keycloak:8080/auth
# Public issuer URL expected in JWT tokens.
# JWT token 中預期的公開 issuer URL。
KEYCLOAK_ISSUER=http://localhost/auth/realms/deep-agent-dev
# JWKS URL used by the API to validate Keycloak JWT signatures.
# API 驗證 Keycloak JWT 簽章使用的 JWKS URL。
KEYCLOAK_JWKS_URL=http://keycloak:8080/auth/realms/deep-agent-dev/protocol/openid-connect/certs

# ============================================================================
# API runtime
# API 執行期設定
# ============================================================================

# Bind host for the FastAPI process inside the container.
# FastAPI 行程在容器內綁定的主機位址。
API_HOST=0.0.0.0
# Human-readable API service name used in logs and health payloads.
# API 服務名稱，用於 log 與 health payload。
API_SERVICE_NAME=deep-agent-api
# API version string returned by service metadata.
# API 版本字串，會出現在服務中繼資料。
API_VERSION=0.1.0
# Comma-separated frontend origins allowed by API CORS.
# API CORS 允許的前端來源，使用逗號分隔。
API_CORS_ORIGINS=http://localhost
# SQLAlchemy database URL used by API and worker.
# API 與 worker 共用的 SQLAlchemy 資料庫連線 URL。
DATABASE_URL=postgresql://postgres:postgres@supabase-db:5432/deep_agent_rag
# Whether SQLAlchemy should print SQL statements in API logs.
# 是否在 API log 中輸出 SQLAlchemy SQL 語句。
DATABASE_ECHO=false
# Redis URL used by the API for coordination and background dispatch.
# API 用於協調與背景任務派送的 Redis URL。
REDIS_URL=redis://redis:6379/0
# Storage backend implementation. Use `minio` for Compose and `filesystem` for local test mode.
# 儲存後端實作。Compose 預設使用 `minio`，本機測試模式可用 `filesystem`。
STORAGE_BACKEND=minio
# MinIO endpoint used by API and worker containers.
# API 與 worker 容器使用的 MinIO endpoint。
MINIO_ENDPOINT=http://minio:9000
# Access key used by API and worker to access MinIO.
# API 與 worker 存取 MinIO 使用的 access key。
MINIO_ACCESS_KEY=minio
# Secret key used by API and worker to access MinIO.
# API 與 worker 存取 MinIO 使用的 secret key。
MINIO_SECRET_KEY=minio123
# Whether MinIO connection should use HTTPS/TLS.
# MinIO 連線是否使用 HTTPS/TLS。
MINIO_SECURE=false
# Bucket name where uploaded document objects are stored.
# 儲存上傳文件物件的 bucket 名稱。
MINIO_BUCKET=documents
# Local fallback storage path used when `STORAGE_BACKEND=filesystem`.
# 當 `STORAGE_BACKEND=filesystem` 時使用的本機儲存路徑。
LOCAL_STORAGE_PATH=.local-storage
# Maximum upload size accepted by the API, in bytes.
# API 可接受的單檔上傳大小上限，單位為 bytes。
MAX_UPLOAD_SIZE_BYTES=5242880
# Enable simplified auth test mode in the API. Do not use for production validation.
# 啟用 API 的簡化 auth test mode。不可用於正式驗證。
AUTH_TEST_MODE=false

# ============================================================================
# PDF parsing / ingest
# PDF 解析 / ingest 設定
# ============================================================================

# PDF parser provider used by worker jobs. `opendataloader` is the default JSON+Markdown path, `local` is the self-hosted Unstructured fallback, and `llamaparse` is the SaaS Markdown path.
# worker job 使用的 PDF parser provider。`opendataloader` 是預設 JSON+Markdown 路徑，`local` 是自架 Unstructured fallback，`llamaparse` 則是 SaaS Markdown 路徑。
PDF_PARSER_PROVIDER=opendataloader
# Whether OpenDataLoader should keep console output quiet.
# 是否讓 OpenDataLoader 以 quiet 模式執行。
OPENDATALOADER_QUIET=true
# Whether OpenDataLoader should prefer tagged PDF structure and fallback automatically when tags are missing.
# 是否讓 OpenDataLoader 優先使用 tagged PDF 結構，並在缺少 tags 時自動 fallback。
OPENDATALOADER_USE_STRUCT_TREE=true
# LlamaParse API key used when `PDF_PARSER_PROVIDER=llamaparse`.
# 當 `PDF_PARSER_PROVIDER=llamaparse` 時使用的 LlamaParse API key。
LLAMAPARSE_API_KEY=
# Ask LlamaParse not to cache uploaded documents.
# 是否要求 LlamaParse 不快取上傳文件。
LLAMAPARSE_DO_NOT_CACHE=false
# Whether LlamaParse should merge continued tables across pages.
# 是否讓 LlamaParse 合併跨頁延續表格。
LLAMAPARSE_MERGE_CONTINUED_TABLES=false

# ============================================================================
# Chunking strategy
# Chunk 切分策略
# ============================================================================

# Minimum parent section length before it is merged with neighboring sections.
# parent section 的最小長度；不足時會先與相鄰 section 合併。
CHUNK_MIN_PARENT_SECTION_LENGTH=800
# Target child chunk size passed to the LangChain recursive splitter, in characters.
# 傳給 LangChain recursive splitter 的 child chunk 目標大小，單位為字元。
CHUNK_TARGET_CHILD_SIZE=800
# Child chunk overlap passed to the LangChain recursive splitter, in characters.
# 傳給 LangChain recursive splitter 的 child chunk overlap，單位為字元。
CHUNK_CHILD_OVERLAP=120
# Maximum preview length stored in `content_preview`, in characters.
# 寫入 `content_preview` 的摘要最大長度，單位為字元。
CHUNK_CONTENT_PREVIEW_LENGTH=120
# Number of TXT paragraphs grouped into one parent section before short-section merging.
# TXT 在短段合併前，每個 parent section 先分組的段落數。
CHUNK_TXT_PARENT_GROUP_SIZE=4
# Maximum table size kept as a single child chunk before row-group splitting, in characters.
# 表格在分列群組前可原封保留為單一 child chunk 的最大字元數。
CHUNK_TABLE_PRESERVE_MAX_CHARS=4000
# Maximum number of data rows kept in each split table child.
# 超大型表格切分時，每個 table child 可包含的最大資料列數。
CHUNK_TABLE_MAX_ROWS_PER_CHILD=20

# ============================================================================
# Background jobs
# 背景工作設定
# ============================================================================

# Celery broker URL used by API dispatch and worker consumption.
# API 派送與 worker 消費共用的 Celery broker URL。
CELERY_BROKER_URL=redis://redis:6379/0
# Celery result backend URL used for task state storage.
# Celery 任務狀態儲存使用的 result backend URL。
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Worker pool implementation.
# Worker 使用的 pool 實作。
CELERY_WORKER_POOL=solo
# Number of concurrent worker processes.
# Worker 同時處理任務的併發數。
CELERY_WORKER_CONCURRENCY=1
# Prefetch multiplier for Celery worker.
# Celery worker 的 prefetch multiplier。
CELERY_WORKER_PREFETCH_MULTIPLIER=1
# Maximum tasks per child process.
# 每個 child process 最多執行的任務數。
CELERY_WORKER_MAX_TASKS_PER_CHILD=1
# Whether unfinished tasks should be acknowledged late.
# 是否在任務完成後才 ack。
CELERY_TASK_ACKS_LATE=true
# Whether to reject tasks when worker process is lost.
# 當 worker 異常中止時，是否拒收並讓任務回到 queue。
CELERY_TASK_REJECT_ON_WORKER_LOST=true

# ============================================================================
# Worker runtime hints
# Worker 執行期提示設定
# ============================================================================

# NVIDIA visible devices passed into the worker container.
# 傳入 worker container 的 NVIDIA_VISIBLE_DEVICES。
NVIDIA_VISIBLE_DEVICES=all
# NVIDIA driver capabilities passed into the worker container.
# 傳入 worker container 的 NVIDIA_DRIVER_CAPABILITIES。
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# ============================================================================
# Embeddings / retrieval / rerank
# Embeddings / retrieval / rerank 設定
# ============================================================================

# Embedding provider used by ingest indexing and query embedding.
# ingest indexing 與 query embedding 使用的 provider。
EMBEDDING_PROVIDER=openai
# Initial embedding model used by OpenAI provider.
# OpenAI provider 初版使用的 embedding model。
EMBEDDING_MODEL=text-embedding-3-small
# Fixed embedding dimensions expected by the current schema.
# 目前 schema 固定預期的 embedding 維度。
EMBEDDING_DIMENSIONS=1536
# OpenAI API key used by API query embedding and worker indexing.
# API query embedding 與 worker indexing 使用的 OpenAI API key。
OPENAI_API_KEY=
# Rerank provider used after RRF merge.
# RRF 後使用的 rerank provider。
# Supported values: `bge`, `qwen`, `cohere`, `easypinex-host`, `deterministic`.
# 支援值：`bge`、`qwen`、`cohere`、`easypinex-host`、`deterministic`。
RERANK_PROVIDER=easypinex-host
# Rerank model used by the API internal retrieval service. `BAAI/bge-reranker-v2-m3`, `Qwen/Qwen3-Reranker-0.6B`
# API internal retrieval service 使用的 rerank model。
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Cohere API key used only when `RERANK_PROVIDER=cohere`.
# 僅在 `RERANK_PROVIDER=cohere` 時使用的 Cohere API key。
COHERE_API_KEY=
# Easypinex-host rerank service base URL used only when `RERANK_PROVIDER=easypinex-host`.
# 僅在 `RERANK_PROVIDER=easypinex-host` 時使用的 easypinex-host rerank service base URL。
EASYPINEX_HOST_RERANK_BASE_URL=http://easypinex.duckdns.org:8000
# Easypinex-host rerank API key used only when `RERANK_PROVIDER=easypinex-host`.
# 僅在 `RERANK_PROVIDER=easypinex-host` 時使用的 easypinex-host rerank API key。
EASYPINEX_HOST_RERANK_API_KEY=
# Easypinex-host rerank request timeout in seconds.
# easypinex-host rerank request timeout 秒數。
EASYPINEX_HOST_RERANK_TIMEOUT_SECONDS=60
# Additional retry attempts allowed only when Cohere returns HTTP 429 Too Many Requests.
# 僅在 Cohere 回傳 HTTP 429 Too Many Requests 時允許的額外重試次數。
RERANK_RETRY_ON_429_ATTEMPTS=4
# Base backoff seconds used for HTTP 429 retries when Cohere does not return a Retry-After header.
# 當 Cohere 未提供 Retry-After header 時，HTTP 429 重試使用的基礎等待秒數。
RERANK_RETRY_ON_429_BACKOFF_SECONDS=16.0
# The default BGE provider downloads the Hugging Face model on first use unless it is already cached locally.
# 預設 BGE provider 會在首次使用時下載 Hugging Face 模型；若本機已快取則直接重用。
# Top-K returned by vector recall before merge.
# merge 前 vector recall 保留的 Top-K。
RETRIEVAL_VECTOR_TOP_K=30
# HNSW ef_search used by PostgreSQL vector recall.
# PostgreSQL vector recall 使用的 HNSW ef_search 參數。
RETRIEVAL_HNSW_EF_SEARCH=100
# Top-K returned by FTS recall before merge.
# merge 前 FTS recall 保留的 Top-K。
RETRIEVAL_FTS_TOP_K=30
# Maximum merged candidates kept after RRF.
# vector + FTS 經過 RRF 合併後，最多保留幾筆。
RETRIEVAL_MAX_CANDIDATES=30
# Enable evidence synopsis hints in the mainline retrieval path.
# 在主線 retrieval 路徑啟用 evidence synopsis 提示文字。
RETRIEVAL_EVIDENCE_SYNOPSIS_ENABLED=true
# Evidence synopsis variant used by the mainline retrieval path.
# 主線 retrieval 路徑使用的 evidence synopsis 變體。
RETRIEVAL_EVIDENCE_SYNOPSIS_VARIANT=qasper_v3
# Reciprocal Rank Fusion smoothing constant.
# Reciprocal Rank Fusion 使用的平滑常數。
RETRIEVAL_RRF_K=60
# Number of top RRF candidates sent into rerank.
# 送進 rerank 的 RRF 前幾名 candidates 數量。
RERANK_TOP_N=30
# Maximum characters sent for each rerank document.
# 每個候選 chunk 送進 rerank 時最多帶多少字元。
RERANK_MAX_CHARS_PER_DOC=2000
# Maximum number of assembled contexts kept after rerank.
# rerank 後 assembler 最多保留的 contexts 數量。
ASSEMBLER_MAX_CONTEXTS=10
# Maximum characters kept in each assembled context.
# 每個組裝後 context 的最大字元數。
ASSEMBLER_MAX_CHARS_PER_CONTEXT=3600
# Maximum number of child chunks merged from the same parent.
# 同一 parent 最多可合併進 assembler 的 child chunks 數量。
ASSEMBLER_MAX_CHILDREN_PER_PARENT=7

# ============================================================================
# Chat runtime
# Chat 執行期設定
# ============================================================================

# Chat answer provider used by LangGraph routes.
# LangGraph 路由使用的 chat answer provider。
CHAT_PROVIDER=deepagents
# Chat model name used by the answer layer.
# answer layer 使用的 chat model 名稱。
CHAT_MODEL=gpt-5-mini
# Maximum output tokens requested from the answer layer.
# answer layer 請求的最大輸出 token 數。
CHAT_MAX_OUTPUT_TOKENS=10000
# Chat answer timeout in seconds.
# chat answer timeout 秒數。
CHAT_TIMEOUT_SECONDS=60
# Whether completed responses should include retrieval and agent trace payloads.
# completed 回應是否附帶 retrieval 與 agent trace。
CHAT_INCLUDE_TRACE=false
# Number of characters emitted in each synthetic `answer_delta` SSE event.
# SSE 串流時，每個合成 answer_delta 事件切幾個字元送出。
CHAT_STREAM_CHUNK_SIZE=1
# Enable backend chat stream timing debug logs.
# 啟用後端 chat stream 時間點 debug log。
CHAT_STREAM_DEBUG=false
# Internal port used by the LangGraph development server in the API container.
# API 容器內 LangGraph development server 使用的內部連接埠。
LANGGRAPH_SERVICE_PORT=8000

# ============================================================================
# LangSmith
# LangSmith 設定
# ============================================================================

# Enable LangSmith tracing for the Deep Agents / LangGraph chat runtime.
# 啟用 Deep Agents / LangGraph chat runtime 的 LangSmith tracing。
LANGSMITH_TRACING=false
# LangSmith API key used to upload traces.
# 上傳 traces 使用的 LangSmith API key。
LANGSMITH_API_KEY=
# LangSmith project name used to group traces from this service.
# 用來分組本服務 traces 的 LangSmith project 名稱。
LANGSMITH_PROJECT=deep-agent-rag-stack
# Optional LangSmith API endpoint.
# 可選的 LangSmith API endpoint。
LANGSMITH_ENDPOINT=
# Optional LangSmith workspace ID for API keys that belong to multiple workspaces.
# 若 API key 綁定多個 workspace，可選填 LangSmith workspace ID。
LANGSMITH_WORKSPACE_ID=

# ============================================================================
# Web frontend
# Web 前端設定
# ============================================================================

# Human-readable worker service name used in logs.
# worker 服務名稱，用於 log 顯示。
WORKER_SERVICE_NAME=deep-agent-worker
# Comma-separated hostnames allowed by the Vite dev server Host header check.
# Vite 開發伺服器允許的 Host header 白名單。
WEB_ALLOWED_HOSTS=localhost,127.0.0.1,easypinex.duckdns.org
# Application title shown in the frontend UI.
# 前端 UI 顯示的應用程式名稱。
VITE_APP_NAME="Deep Agent RAG Stack"
# Public API base URL used by the frontend.
# 前端呼叫 API 使用的公開基底 URL。
VITE_API_BASE_URL=http://localhost/api
# Frontend auth mode. Use `keycloak` normally and `test` only for automated tests.
# 前端驗證模式。正式流程用 `keycloak`，自動化測試才用 `test`。
VITE_AUTH_MODE=keycloak
# Public Keycloak base URL used by the frontend.
# 前端使用的公開 Keycloak 基底 URL。
VITE_KEYCLOAK_URL=http://localhost/auth
# Keycloak realm used by the frontend login flow.
# 前端登入流程使用的 Keycloak realm 名稱。
VITE_KEYCLOAK_REALM=deep-agent-dev
# Keycloak client ID used by the frontend login flow.
# 前端登入流程使用的 Keycloak client ID。
VITE_KEYCLOAK_CLIENT_ID=deep-agent-web
# Enable browser console chat stream timing debug logs.
# 啟用瀏覽器 console 的 chat stream 時間點 debug log。
VITE_CHAT_STREAM_DEBUG=false
