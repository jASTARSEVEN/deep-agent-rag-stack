# Root environment template for local Docker Compose development.
# 本機 Docker Compose 開發使用的根目錄環境變數範本。

# ============================================================================
# Compose project
# Docker Compose 專案設定
# ============================================================================

# Docker Compose project name used for container, network, and volume prefixes.
# Docker Compose 專案名稱，會影響 container、network、volume 的前綴。
COMPOSE_PROJECT_NAME=deep-agent-rag-stack

# ============================================================================
# Application database
# 應用程式資料庫
# ============================================================================

# PostgreSQL application database name.
# 應用程式 PostgreSQL 資料庫名稱。
POSTGRES_DB=deep_agent_rag
# PostgreSQL application database username.
# 應用程式 PostgreSQL 資料庫使用者名稱。
POSTGRES_USER=app
# PostgreSQL application database password.
# 應用程式 PostgreSQL 資料庫密碼。
POSTGRES_PASSWORD=app
# Host port exposed for the application PostgreSQL container.
# 應用程式 PostgreSQL 容器對外暴露的主機連接埠。
POSTGRES_PORT=15432

# ============================================================================
# Redis
# Redis 設定
# ============================================================================

# Host port exposed for the Redis container.
# Redis 容器對外暴露的主機連接埠。
REDIS_PORT=16379

# ============================================================================
# MinIO infrastructure
# MinIO 基礎設施設定
# ============================================================================

# MinIO root username for object storage administration.
# MinIO 物件儲存管理用 root 使用者名稱。
MINIO_ROOT_USER=minio
# MinIO root password for object storage administration.
# MinIO 物件儲存管理用 root 密碼。
MINIO_ROOT_PASSWORD=minio123
# Host port exposed for the MinIO S3-compatible API.
# MinIO S3 相容 API 對外暴露的主機連接埠。
MINIO_PORT=19000
# Host port exposed for the MinIO console UI.
# MinIO 管理主控台 UI 對外暴露的主機連接埠。
MINIO_CONSOLE_PORT=19001
# Default bucket name created and used for uploaded documents.
# 預設建立並用於文件上傳的 bucket 名稱。
MINIO_DEFAULT_BUCKET=documents

# ============================================================================
# Keycloak infrastructure
# Keycloak 基礎設施設定
# ============================================================================

# Keycloak backing database name.
# Keycloak 後端資料庫名稱。
KEYCLOAK_DB=keycloak
# Keycloak backing database username.
# Keycloak 後端資料庫使用者名稱。
KEYCLOAK_DB_USER=keycloak
# Keycloak backing database password.
# Keycloak 後端資料庫密碼。
KEYCLOAK_DB_PASSWORD=keycloak
# Host port exposed for the Keycloak PostgreSQL container.
# Keycloak PostgreSQL 容器對外暴露的主機連接埠。
KEYCLOAK_DB_PORT=15433
# Host port exposed for the Keycloak HTTP service.
# Keycloak HTTP 服務對外暴露的主機連接埠。
KEYCLOAK_PORT=18080
# Initial Keycloak admin username.
# 初始 Keycloak 管理者帳號。
KEYCLOAK_ADMIN=admin
# Initial Keycloak admin password.
# 初始 Keycloak 管理者密碼。
KEYCLOAK_ADMIN_PASSWORD=admin
# Realm name imported into Keycloak for local development.
# 本機開發時匯入 Keycloak 的 realm 名稱。
KEYCLOAK_REALM=deep-agent-dev
# Frontend Keycloak client ID used by the web app.
# 前端 web app 使用的 Keycloak client ID。
KEYCLOAK_CLIENT_ID=deep-agent-web

# ============================================================================
# API runtime
# API 執行期設定
# ============================================================================

# Host port exposed for the FastAPI service.
# FastAPI 服務對外暴露的主機連接埠。
API_PORT=18000
# Bind host for the FastAPI process inside the container.
# FastAPI 行程在容器內綁定的主機位址。
API_HOST=0.0.0.0
# Human-readable API service name used in logs and health payloads.
# API 服務名稱，用於 log 與 health payload。
API_SERVICE_NAME=deep-agent-api
# API version string returned by service metadata.
# API 版本字串，會出現在服務中繼資料。
API_VERSION=0.1.0
# Comma-separated frontend origins allowed by API CORS.
# API CORS 允許的前端來源，使用逗號分隔。
API_CORS_ORIGINS=http://localhost:3000,http://localhost:13000
# SQLAlchemy database URL used by API and worker.
# API 與 worker 共用的 SQLAlchemy 資料庫連線 URL。
DATABASE_URL=postgresql://app:app@postgres:5432/deep_agent_rag
# Whether SQLAlchemy should print SQL statements in API logs.
# 是否在 API log 中輸出 SQLAlchemy SQL 語句。
DATABASE_ECHO=false
# Redis URL used by the API for coordination and background dispatch.
# API 用於協調與背景任務派送的 Redis URL。
REDIS_URL=redis://redis:6379/0
# Storage backend implementation. Use `minio` for Compose and `filesystem` for local test mode.
# 儲存後端實作。Compose 預設使用 `minio`，本機測試模式可用 `filesystem`。
STORAGE_BACKEND=minio
# MinIO endpoint used by API and worker containers.
# API 與 worker 容器使用的 MinIO endpoint。
MINIO_ENDPOINT=http://minio:9000
# Access key used by API and worker to access MinIO.
# API 與 worker 存取 MinIO 使用的 access key。
MINIO_ACCESS_KEY=minio
# Secret key used by API and worker to access MinIO.
# API 與 worker 存取 MinIO 使用的 secret key。
MINIO_SECRET_KEY=minio123
# Whether MinIO connection should use HTTPS/TLS.
# MinIO 連線是否使用 HTTPS/TLS。
MINIO_SECURE=false
# Bucket name where uploaded document objects are stored.
# 儲存上傳文件物件的 bucket 名稱。
MINIO_BUCKET=documents
# Local fallback storage path used when `STORAGE_BACKEND=filesystem`.
# 當 `STORAGE_BACKEND=filesystem` 時使用的本機儲存路徑。
LOCAL_STORAGE_PATH=.local-storage
# Maximum upload size accepted by the API, in bytes.
# API 可接受的單檔上傳大小上限，單位為 bytes。
MAX_UPLOAD_SIZE_BYTES=5242880

# ============================================================================
# Chunking strategy
# Chunk 切分策略
# ============================================================================

# Minimum parent section length before it is merged with neighboring sections.
# parent section 的最小長度；不足時會先與相鄰 section 合併。
CHUNK_MIN_PARENT_SECTION_LENGTH=800
# Target child chunk size passed to the LangChain recursive splitter, in characters.
# 傳給 LangChain recursive splitter 的 child chunk 目標大小，單位為字元。
CHUNK_TARGET_CHILD_SIZE=800
# Child chunk overlap passed to the LangChain recursive splitter, in characters.
# 傳給 LangChain recursive splitter 的 child chunk overlap，單位為字元。
CHUNK_CHILD_OVERLAP=120
# Maximum preview length stored in `content_preview`, in characters.
# 寫入 `content_preview` 的摘要最大長度，單位為字元。
CHUNK_CONTENT_PREVIEW_LENGTH=120
# Number of TXT paragraphs grouped into one parent section before short-section merging.
# TXT 在短段合併前，每個 parent section 先分組的段落數。
CHUNK_TXT_PARENT_GROUP_SIZE=4
# Maximum table size kept as a single child chunk before row-group splitting, in characters.
# 表格在分列群組前可原封保留為單一 child chunk 的最大字元數。
CHUNK_TABLE_PRESERVE_MAX_CHARS=4000
# Maximum number of data rows kept in each split table child.
# 超大型表格切分時，每個 table child 可包含的最大資料列數。
CHUNK_TABLE_MAX_ROWS_PER_CHILD=20

# ============================================================================
# Background jobs
# 背景工作設定
# ============================================================================

# Celery broker URL used by API dispatch and worker consumption.
# API 派送與 worker 消費共用的 Celery broker URL。
CELERY_BROKER_URL=redis://redis:6379/0
# Celery result backend URL used for task state storage.
# Celery 任務狀態儲存使用的 result backend URL。
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Run ingest inline inside the API process. Only for tests or local debugging.
# 是否在 API 行程內同步執行 ingest。僅供測試或本機除錯。
INGEST_INLINE_MODE=false
# Internal Keycloak base URL used by the API container.
# API 容器內部使用的 Keycloak 基底 URL。
KEYCLOAK_URL=http://keycloak:8080
# Public issuer URL expected in JWT tokens.
# JWT token 中預期的公開 issuer URL。
KEYCLOAK_ISSUER=http://localhost:18080/realms/deep-agent-dev
# JWKS URL used by the API to validate Keycloak JWT signatures.
# API 驗證 Keycloak JWT 簽章使用的 JWKS URL。
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/deep-agent-dev/protocol/openid-connect/certs
# JWT claim name that carries Keycloak groups.
# JWT 中承載 Keycloak groups 的 claim 名稱。
KEYCLOAK_GROUPS_CLAIM=groups
# Enable simplified auth test mode in the API. Do not use for production validation.
# 啟用 API 的簡化 auth test mode。不可用於正式驗證。
AUTH_TEST_MODE=false
#
# Embedding provider used by ingest indexing and query embedding.
# ingest indexing 與 query embedding 使用的 provider。
EMBEDDING_PROVIDER=openai
# Initial embedding model used by OpenAI provider.
# OpenAI provider 初版使用的 embedding model。
EMBEDDING_MODEL=text-embedding-3-small
# Fixed embedding dimensions expected by the current schema.
# 目前 schema 固定預期的 embedding 維度。
EMBEDDING_DIMENSIONS=1536
# OpenAI API key used by API query embedding and worker indexing.
# API query embedding 與 worker indexing 使用的 OpenAI API key。
OPENAI_API_KEY=
# Rerank provider used after RRF merge. Compose 建議使用 `cohere`，測試可改為 `deterministic`。
# RRF 後使用的 rerank provider。Compose 建議使用 `cohere`，測試可改為 `deterministic`。
RERANK_PROVIDER=cohere
# Cohere rerank model used by the API internal retrieval service.
# API internal retrieval service 使用的 Cohere rerank model。
RERANK_MODEL=rerank-v3.5
# Cohere API key used by internal retrieval rerank.
# internal retrieval rerank 使用的 Cohere API key。
COHERE_API_KEY=
# Top-K returned by vector recall before merge.
# merge 前 vector recall 保留的 Top-K。
RETRIEVAL_VECTOR_TOP_K=30
# HNSW ef_search used by PostgreSQL vector recall.
# PostgreSQL vector recall 使用的 HNSW ef_search 參數。
RETRIEVAL_HNSW_EF_SEARCH=100
# PostgreSQL text search configuration used by retrieval FTS.
# retrieval FTS 使用的 PostgreSQL text search configuration 名稱。
TEXT_SEARCH_CONFIG=deep_agent_jieba
# Top-K returned by FTS recall before merge.
# merge 前 FTS recall 保留的 Top-K。
RETRIEVAL_FTS_TOP_K=30
# Maximum merged candidates kept after RRF.
# vector + FTS 經過 RRF 合併後，最多保留幾筆。
RETRIEVAL_MAX_CANDIDATES=30
# Reciprocal Rank Fusion smoothing constant.
# Reciprocal Rank Fusion 使用的平滑常數。
RETRIEVAL_RRF_K=60
# Number of top RRF candidates sent into rerank.
# 送進 rerank 的 RRF 前幾名 candidates 數量。
RERANK_TOP_N=30
# Maximum characters sent for each rerank document.
# 每個候選 chunk 送進 rerank 時最多帶多少字元。
RERANK_MAX_CHARS_PER_DOC=2000
# Maximum number of assembled contexts kept after rerank.
# rerank 後 assembler 最多保留的 contexts 數量。
ASSEMBLER_MAX_CONTEXTS=6
# Maximum characters kept in each assembled context.
# 每個組裝後 context 的最大字元數。
ASSEMBLER_MAX_CHARS_PER_CONTEXT=6000
# Maximum number of child chunks merged from the same parent.
# 同一 parent 最多可合併進 assembler 的 child chunks 數量。
ASSEMBLER_MAX_CHILDREN_PER_PARENT=3
# Chat answer provider used by LangGraph bridge routes. Use `deterministic` for offline tests or `deepagents` for model-backed answers.
# LangGraph bridge routes 使用的 chat answer provider。離線測試可用 `deterministic`，模型回答可用 `deepagents`。
CHAT_PROVIDER=deepagents
# Chat model name used by the answer layer.
# answer layer 使用的 chat model 名稱。
CHAT_MODEL=gpt-5-mini
# Maximum output tokens requested from the answer layer.
# answer layer 請求的最大輸出 token 數。
CHAT_MAX_OUTPUT_TOKENS=10000
# Chat answer timeout in seconds.
# chat answer timeout 秒數。
CHAT_TIMEOUT_SECONDS=60
# Whether sync/completed responses should include retrieval and agent trace payloads.
# sync/completed 回應是否附帶 retrieval 與 agent trace。
CHAT_INCLUDE_TRACE=false
# Number of characters emitted in each synthetic `answer_delta` SSE event.
# SSE 串流時，每個合成 answer_delta 事件切幾個字元送出, 越小越即時
CHAT_STREAM_CHUNK_SIZE=1
# Internal port used by the LangGraph development server in the API container.
# API 容器內 LangGraph development server 使用的內部連接埠。
LANGGRAPH_SERVICE_PORT=8000

# ============================================================================
# PostgreSQL extension build
# PostgreSQL 擴充套件建置設定
# ============================================================================

# Git repository URL used to build the required pg_jieba fork.
# 建置指定 pg_jieba fork 時使用的 Git repository URL。
PG_JIEBA_REPO_URL=https://github.com/easypinex/pg_jieba.git
# Git ref, branch, or commit used when building the required pg_jieba fork.
# 建置指定 pg_jieba fork 時使用的 Git ref、branch 或 commit。
PG_JIEBA_REF=9cacff0f52fb912060ab96f235970b4a9e7ac3a3

# ============================================================================
# Worker runtime
# Worker 執行期設定
# ============================================================================

# Human-readable worker service name used in logs.
# worker 服務名稱，用於 log 顯示。
WORKER_SERVICE_NAME=deep-agent-worker

# ============================================================================
# Web frontend
# Web 前端設定
# ============================================================================

# Host port exposed for the web frontend container.
# web 前端容器對外暴露的主機連接埠。
WEB_PORT=13000
# Application title shown in the frontend UI.
# 前端 UI 顯示的應用程式名稱。
VITE_APP_NAME=Deep Agent RAG Stack
# Public API base URL used by the frontend.
# 前端呼叫 API 使用的公開基底 URL。
VITE_API_BASE_URL=http://localhost:18000
# Frontend auth mode. Use `keycloak` normally and `test` only for automated tests.
# 前端驗證模式。正式本機流程用 `keycloak`，自動化測試才用 `test`。
VITE_AUTH_MODE=keycloak
# Public Keycloak base URL used by the frontend.
# 前端使用的公開 Keycloak 基底 URL。
VITE_KEYCLOAK_URL=http://localhost:18080
# Keycloak realm used by the frontend login flow.
# 前端登入流程使用的 Keycloak realm 名稱。
VITE_KEYCLOAK_REALM=deep-agent-dev
# Keycloak client ID used by the frontend login flow.
# 前端登入流程使用的 Keycloak client ID。
VITE_KEYCLOAK_CLIENT_ID=deep-agent-web
