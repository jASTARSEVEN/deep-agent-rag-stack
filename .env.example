# Root environment template for local Docker Compose development.
# 本機 Docker Compose 開發使用的根目錄環境變數範本。
#
# This template intentionally focuses on the common Compose startup variables.
# 這份範本刻意只保留最常用的 Compose 啟動設定。
# Add extra API / worker runtime overrides only when you actually need them.
# 只有在真的需要時，再額外補上 API / worker 執行期覆寫參數。

# ============================================================================
# Public reverse proxy / TLS
# 對外 reverse proxy / TLS 設定
# ============================================================================

# Public hostname served by Caddy.
# Caddy 對外服務使用的公開 hostname。
PUBLIC_HOST=localhost
# Public origin used by browser-facing routes. Compose derives `/api` and `/auth`
# from this value, so keep it aligned with `PUBLIC_HOST`.
# 提供瀏覽器使用的公開 origin。Compose 會由此推導 `/api` 與 `/auth`，
# 請與 `PUBLIC_HOST` 保持一致。
PUBLIC_BASE_URL=http://localhost
# ACME contact email used by Caddy automatic HTTPS.
# Caddy 自動申請與續約憑證使用的 ACME 聯絡信箱。
TLS_ACME_EMAIL=admin@example.com
# Whether to use the Let's Encrypt staging CA.
# 是否使用 Let's Encrypt staging CA，避免正式 rate limit。
TLS_ACME_STAGING=false
# Whether Keycloak admin console should be exposed through the reverse proxy.
# 是否透過 reverse proxy 對外公開 Keycloak admin console。
KEYCLOAK_EXPOSE_ADMIN=false

# ============================================================================
# Application database
# 應用程式資料庫
# ============================================================================

# PostgreSQL application database name.
# 應用程式 PostgreSQL 資料庫名稱。
POSTGRES_DB=deep_agent_rag
# PostgreSQL application database username.
# 應用程式 PostgreSQL 資料庫使用者名稱。Supabase Postgres init scripts 預設需要 `postgres` superuser。
POSTGRES_USER=postgres
# PostgreSQL application database password.
# 應用程式 PostgreSQL 資料庫密碼。
POSTGRES_PASSWORD=postgres
# Host port exposed for the application PostgreSQL container.
# 應用程式 PostgreSQL 容器對外暴露的主機連接埠。
POSTGRES_PORT=15432

# ============================================================================
# Redis
# Redis 設定
# ============================================================================

# Host port exposed for the Redis container.
# Redis 容器對外暴露的主機連接埠。
REDIS_PORT=16379

# ============================================================================
# MinIO infrastructure
# MinIO 基礎設施設定
# ============================================================================

# MinIO root username for object storage administration.
# MinIO 物件儲存管理用 root 使用者名稱。
MINIO_ROOT_USER=minio
# MinIO root password for object storage administration.
# MinIO 物件儲存管理用 root 密碼。
MINIO_ROOT_PASSWORD=minio123
# Host port exposed for the MinIO S3-compatible API.
# MinIO S3 相容 API 對外暴露的主機連接埠。
MINIO_PORT=19000
# Host port exposed for the MinIO console UI.
# MinIO 管理主控台 UI 對外暴露的主機連接埠。
MINIO_CONSOLE_PORT=19001
# Bucket name used for uploaded documents.
# 文件上傳使用的 bucket 名稱。
MINIO_BUCKET=documents

# ============================================================================
# Keycloak infrastructure
# Keycloak 基礎設施設定
# ============================================================================

# Initial Keycloak admin username.
# 初始 Keycloak 管理者帳號。
KEYCLOAK_ADMIN=admin
# Initial Keycloak admin password.
# 初始 Keycloak 管理者密碼。
KEYCLOAK_ADMIN_PASSWORD=admin
# Realm name imported into Keycloak for local development.
# 本機開發時匯入 Keycloak 的 realm 名稱。
KEYCLOAK_REALM=deep-agent-dev
# Keycloak OIDC client ID used by the web frontend.
# Web 前端登入流程使用的 Keycloak client ID。
KEYCLOAK_CLIENT_ID=deep-agent-web
# JWT claim name that carries Keycloak groups.
# JWT 中承載 Keycloak groups 的 claim 名稱。
KEYCLOAK_GROUPS_CLAIM=groups

# ============================================================================
# Storage / API runtime
# 儲存 / API 執行期設定
# ============================================================================

# Storage backend implementation. Use `minio` for Compose and `filesystem` for local test mode.
# 儲存後端實作。Compose 預設使用 `minio`，本機測試模式可用 `filesystem`。
STORAGE_BACKEND=minio
# Local fallback storage path used when `STORAGE_BACKEND=filesystem`.
# 當 `STORAGE_BACKEND=filesystem` 時使用的本機儲存路徑。
LOCAL_STORAGE_PATH=.local-storage
# Maximum upload size accepted by the API, in bytes.
# API 可接受的單檔上傳大小上限，單位為 bytes。
MAX_UPLOAD_SIZE_BYTES=5242880

# ============================================================================
# PDF parsing / ingest
# PDF 解析 / ingest 設定
# ============================================================================

# PDF parser provider used by worker jobs. `opendataloader` is the default JSON+Markdown path,
# `local` is the self-hosted Unstructured fallback, and `llamaparse` is the SaaS Markdown path.
# worker job 使用的 PDF parser provider。`opendataloader` 是預設 JSON+Markdown 路徑，
# `local` 是自架 Unstructured fallback，`llamaparse` 則是 SaaS Markdown 路徑。
PDF_PARSER_PROVIDER=opendataloader
# Whether OpenDataLoader should keep console output quiet.
# 是否讓 OpenDataLoader 以 quiet 模式執行。
OPENDATALOADER_QUIET=true
# Whether OpenDataLoader should prefer tagged PDF structure and fallback automatically when tags are missing.
# 是否讓 OpenDataLoader 優先使用 tagged PDF 結構，並在缺少 tags 時自動 fallback。
OPENDATALOADER_USE_STRUCT_TREE=true
# LlamaParse API key used when `PDF_PARSER_PROVIDER=llamaparse`.
# 當 `PDF_PARSER_PROVIDER=llamaparse` 時使用的 LlamaParse API key。
LLAMAPARSE_API_KEY=

# ============================================================================
# Worker runtime hints
# Worker 執行期提示設定
# ============================================================================

# NVIDIA visible devices passed into the worker container.
# 傳入 worker container 的 NVIDIA_VISIBLE_DEVICES。
NVIDIA_VISIBLE_DEVICES=all
# NVIDIA driver capabilities passed into the worker container.
# 傳入 worker container 的 NVIDIA_DRIVER_CAPABILITIES。
NVIDIA_DRIVER_CAPABILITIES=compute,utility
# Optional API dependency groups installed at Docker build time.
# Docker build 時要額外安裝到 API image 的 optional dependency groups。
# 例如使用本機 Hugging Face rerank 時可設為 `local-huggingface`。
API_INSTALL_OPTIONAL_GROUPS=
# Optional worker dependency groups installed at Docker build time.
# Docker build 時要額外安裝到 worker image 的 optional dependency groups。
# 例如使用本機 Hugging Face embedding 時可設為 `local-huggingface`。
WORKER_INSTALL_OPTIONAL_GROUPS=

# ============================================================================
# Embeddings / rerank providers
# Embeddings / rerank provider 設定
# ============================================================================

# Embedding provider used by ingest indexing and query embedding.
# ingest indexing 與 query embedding 使用的 provider。
# Supported values: `openai`, `self-hosted`, `openrouter`, `huggingface`.
# 支援值：`openai`、`self-hosted`、`openrouter`、`huggingface`。
EMBEDDING_PROVIDER=openai
# Initial embedding model used by the selected embedding provider.
# 選定 embedding provider 使用的 embedding model。
EMBEDDING_MODEL=text-embedding-3-small
# OpenAI API key used by API query embedding and worker indexing.
# API query embedding 與 worker indexing 使用的 OpenAI API key。
OPENAI_API_KEY=
# OpenRouter API key used by API query embedding and worker indexing.
# API query embedding 與 worker indexing 使用的 OpenRouter API key。
OPENROUTER_API_KEY=
# Optional HTTP-Referer header sent to OpenRouter.
# 傳給 OpenRouter 的可選 HTTP-Referer header。
OPENROUTER_HTTP_REFERER=
# Optional X-OpenRouter-Title header sent to OpenRouter.
# 傳給 OpenRouter 的可選 X-OpenRouter-Title header。
OPENROUTER_TITLE=
# Self-hosted embedding service base URL used when `EMBEDDING_PROVIDER=self-hosted`.
# 僅在 `EMBEDDING_PROVIDER=self-hosted` 時使用的自架 embedding service base URL。
SELF_HOSTED_EMBEDDING_BASE_URL=http://easypinex.duckdns.org:8000
# Self-hosted embedding API key used when `EMBEDDING_PROVIDER=self-hosted`.
# 僅在 `EMBEDDING_PROVIDER=self-hosted` 時使用的自架 embedding API key。
SELF_HOSTED_EMBEDDING_API_KEY=
# Self-hosted embedding request timeout in seconds.
# 自架 embedding request timeout 秒數。
SELF_HOSTED_EMBEDDING_TIMEOUT_SECONDS=60
# Rerank provider used after RRF merge.
# RRF 後使用的 rerank provider。
# Supported values: `self-hosted`, `huggingface`, `cohere`, `deterministic`.
# 支援值：`self-hosted`、`huggingface`、`cohere`、`deterministic`。
RERANK_PROVIDER=self-hosted
# Rerank model used by the API internal retrieval service.
# API internal retrieval service 使用的 rerank model。
RERANK_MODEL=BAAI/bge-reranker-v2-m3
# Cohere API key used only when `RERANK_PROVIDER=cohere`.
# 僅在 `RERANK_PROVIDER=cohere` 時使用的 Cohere API key。
COHERE_API_KEY=
# Self-hosted rerank service base URL used when `RERANK_PROVIDER=self-hosted`.
# 僅在 `RERANK_PROVIDER=self-hosted` 時使用的自架 rerank service base URL。
SELF_HOSTED_RERANK_BASE_URL=http://easypinex.duckdns.org:8000
# Self-hosted rerank API key used when `RERANK_PROVIDER=self-hosted`.
# 僅在 `RERANK_PROVIDER=self-hosted` 時使用的自架 rerank API key。
SELF_HOSTED_RERANK_API_KEY=
# Self-hosted rerank request timeout in seconds.
# 自架 rerank request timeout 秒數。
SELF_HOSTED_RERANK_TIMEOUT_SECONDS=60

# ============================================================================
# Chat / observability
# Chat / observability 設定
# ============================================================================

# Chat model name used by the answer layer.
# answer layer 使用的 chat model 名稱。
CHAT_MODEL=gpt-5-mini
# Enable LangSmith tracing for the Deep Agents / LangGraph chat runtime.
# 啟用 Deep Agents / LangGraph chat runtime 的 LangSmith tracing。
LANGSMITH_TRACING=false
# LangSmith API key used to upload traces.
# 上傳 traces 使用的 LangSmith API key。
LANGSMITH_API_KEY=
# LangSmith project name used to group traces from this service.
# 用來分組本服務 traces 的 LangSmith project 名稱。
LANGSMITH_PROJECT=deep-agent-rag-stack

# ============================================================================
# Frontend
# 前端設定
# ============================================================================

# Application title shown in the frontend UI.
# 前端 UI 顯示的應用程式名稱。
VITE_APP_NAME=Deep Agent RAG Stack
# Enable browser console chat stream timing debug logs.
# 啟用瀏覽器 console 的 chat stream 時間點 debug log。
VITE_CHAT_STREAM_DEBUG=false

# ============================================================================
# Advanced runtime overrides
# 進階執行期覆寫
# ============================================================================

# Most retrieval, chunking, Celery, and debug knobs fall back to application defaults.
# Compose still accepts extra overrides when you add them manually to `.env`.
# 多數 retrieval、chunking、Celery 與 debug 參數會回退到應用程式內建預設值。
# 若真的要微調，仍可自行把額外 env var 加進 `.env`。
